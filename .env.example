# Exalted Agent Trading Lab — configuration template
# Copy to .env and fill in your keys. Paper trading only; no live-trading mode exists.
#
# Risk values here are PLATFORM WALLS. Each team chooses its own parameters
# (position size, gross exposure, cycle speed, instruments) in its charter and
# can change them any cycle — but every charter value is clamped to these.

# --- Team Alpaca paper accounts (create two paper accounts at alpaca.markets) ---
TEAM_ALPHA_ALPACA_API_KEY=
TEAM_ALPHA_ALPACA_SECRET_KEY=
TEAM_BETA_ALPACA_API_KEY=
TEAM_BETA_ALPACA_SECRET_KEY=

# --- LLM provider (openai | anthropic | ollama) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=            # if LLM_PROVIDER=anthropic
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1   # if LLM_PROVIDER=ollama
LLM_MODEL=gpt-5.4-nano
# Optional per-agent overrides (default to LLM_MODEL):
LLM_MODEL_STRATEGIST=gpt-5.4-mini
# LLM_MODEL_RESEARCHER=
# LLM_MODEL_RISK=

# Researcher may search the live web (OpenAI web_search tool). true|false
ENABLE_WEB_RESEARCH=true

# --- Loop ---
DRY_RUN=false                   # true = full pipeline but never submit orders
MIN_CYCLE_MINUTES=5             # fastest cadence a team may choose
MAX_CYCLE_MINUTES=120

# --- Platform hard caps (teams can NEVER exceed these) ---
MAX_POSITION_PCT=0.30           # ceiling on a single position, fraction of equity
MAX_GROSS_EXPOSURE=2.0          # ceiling on sum(|positions|)/equity (paper margin)
MAX_ORDERS_PER_DAY=100          # per team, New York trading date
MAX_DAILY_NOTIONAL=2000000      # per team, dollars per day
ALLOW_SHORTS=true
ALLOW_MARGIN=true
ALLOW_OPTIONS=true              # LONG calls/puts only; never naked selling
MAX_OPTION_PREMIUM_PCT=0.03     # premium at risk per option trade
MAX_TOTAL_OPTION_PREMIUM_PCT=0.10
MAX_PROPOSALS_PER_CYCLE=3

# --- Optional extras ---
# WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA,TSLA,AMD,META,GOOGL,AMZN   # protected core symbols
# DISCORD_BOT_TOKEN=            # post trades, debriefs, rebuttals, errors to Discord
# DISCORD_CHANNEL_ID=
