# Alpaca paper trading only.
# Never commit real keys.
# Generic Alpaca keys are optional when using TEAM_ALPHA_* and TEAM_BETA_* paper keys.

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

DATABASE_PATH=data/trading_lab.sqlite3

DRY_RUN=true
STARTING_EQUITY=1000000
MIN_CASH_PCT=0.10
MAX_POSITION_PCT=0.20
MAX_DAILY_TURNOVER_PCT=0.30
MAX_NEW_POSITIONS_PER_DAY=10

# --- Paper trading permission levels (paper-only; advanced levels default OFF) ---
# TRADING_MODE must be paper. Any non-paper value disables all advanced surfaces.
TRADING_MODE=paper
ENABLE_PAPER_STOCKS=true
ENABLE_PAPER_SHORTING=false
ENABLE_PAPER_MARGIN=false
ENABLE_PAPER_OPTIONS=false

# Per-team activity + exposure + options caps (deterministic risk engine).
MAX_DAILY_ORDERS_PER_TEAM=3
MAX_DAILY_LOSS_PCT_PER_TEAM=0.02
MAX_POSITION_WEIGHT=0.20
MAX_GROSS_EXPOSURE=1.50
MAX_NET_EXPOSURE=1.20
MAX_SHORT_EXPOSURE=0.30
MAX_SINGLE_SHORT_WEIGHT=0.10
MAX_OPTIONS_PREMIUM_AT_RISK=0.02
MAX_OPTIONS_CONTRACTS_PER_TRADE=2
MIN_OPTIONS_DTE=7
ALLOW_NAKED_OPTIONS=false
# Paper options execution: single-leg long calls/puts execute by default.
# Multileg spreads stay OFF unless explicitly enabled (runtime MLEG support uncertain).
ENABLE_PAPER_OPTION_SPREADS=false

# --- LLM provider abstraction (proposal/review/learning JSON only; never trades) ---
# Choose one: openai | anthropic | ollama. Hosted keys never reach the broker.
EXALTED_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=llama3.2

# --- Task-specific LLM model routing (Phase 7O): cheaper models for cheap tasks ---
# Resolution per task: LLM_MODEL_<TASK> -> LLM_MODEL -> OPENAI_MODEL -> built-in default.
# Use a stronger model for strategy/proposal decisions; cheaper models elsewhere.
# LLM_PROVIDER is an alias fallback for EXALTED_LLM_PROVIDER.
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-mini
LLM_MODEL_STRATEGY=gpt-5.4-mini
LLM_MODEL_PORTFOLIO_MANAGER=gpt-5.4-mini
LLM_MODEL_REVIEW=gpt-5.4-nano
LLM_MODEL_CRITIQUE=gpt-5.4-nano
LLM_MODEL_SUMMARY=gpt-5.4-nano
LLM_MODEL_RESEARCH_SYNTHESIS=gpt-5.4-nano

# --- LLM-backed advisory review agents (Phase 7P) ---
# These stages use the routed (cheap) models above to IMPROVE reasoning + written
# strategy quality. They are ADVISORY ONLY: the deterministic risk engine and
# PortfolioManager remain authoritative. None of these can widen caps, unblock
# buys, bypass risk/review approvals, authorize options/spreads, or change
# credentials/broker mode. Each falls back to deterministic text if disabled or
# if the provider fails.
# Portfolio manager is closest to trade decisions -> default OFF (conservative).
ENABLE_LLM_PORTFOLIO_MANAGER=false
ENABLE_LLM_REVIEW_AGENT=true
ENABLE_LLM_CRITIQUE_AGENT=true
ENABLE_LLM_SUMMARY_AGENT=true
# Research synthesis stays OFF until proven valuable. No web search in this phase.
ENABLE_LLM_RESEARCH_SYNTHESIS=false
ENABLE_LLM_DAILY_REVIEW=true

# Weekly competition proposal source: default (deterministic) or llm (provider).
# Used when --proposal-source is omitted on run-week-cycle.
WEEK_COMPETITION_PROPOSAL_SOURCE=default

# --- Portfolio Manager / Capital Allocator (Phase 7M) ---
# Teams review the book before trading: hold/trim/close/rotate/add/hedge/no-trade.
# These tune behavior + cost; platform hard caps above always win.
PORTFOLIO_MANAGER_ENABLED=true
# Block new-money buys when buying power drops below this fraction of equity
# (triggers a portfolio review instead of hard-stopping the cycle).
LOW_BUYING_POWER_REVIEW_THRESHOLD_PCT=0.15
ALLOW_NO_TRADE_DECISIONS=true
# Dynamic new-proposal caps (clamped by MAX_DAILY_ORDERS_PER_TEAM).
MAX_NEW_PROPOSALS_ALPHA=3
MAX_NEW_PROPOSALS_BETA=2

# Attribution outcome verdict band (|excess vs SPY|) for refresh-proposal-attribution.
ATTRIBUTION_OUTCOME_THRESHOLD=0.005

# --- Cheap cycle gate (Phase 7N): only spend LLM cycles when useful ---
# When enabled, cheap-cycle-gate recommends skipping a full run-week-cycle unless the
# minimum interval elapsed or something material changed (major SPY move, broker rejections).
CHEAP_CYCLE_GATE_ENABLED=true
MIN_FULL_CYCLE_INTERVAL_MINUTES_ALPHA=30
MIN_FULL_CYCLE_INTERVAL_MINUTES_BETA=45
FORCE_FULL_CYCLE_ON_MAJOR_MOVE=true
MAJOR_SPY_MOVE_THRESHOLD_PCT=0.5
# Low buying power recommends a (cheap) review by default, not a forced full trading cycle.
FORCE_FULL_CYCLE_ON_LOW_BUYING_POWER=false

# Allowlisted research providers (off by default; safe). No scraping.
# NEWS_PROVIDER: none | alpaca | openai_web | hybrid
ENABLE_LIVE_NEWS_RESEARCH=false
NEWS_PROVIDER=none
ENABLE_OPENAI_WEB_RESEARCH=false
OPENAI_WEB_RESEARCH_MODEL=gpt-5.4-mini
MAX_RESEARCH_QUERIES_PER_TEAM_PER_CYCLE=5
MAX_RESEARCH_RESULTS_PER_QUERY=5
RESEARCH_LOOKBACK_HOURS=24
RESEARCH_WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA,TSLA,AMD,META,GOOGL,AMZN

# Optional local Discord command-center bot.
# Do not commit real tokens or IDs.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_DEFAULT_REGISTRY=docs/examples/hermes_team_registry_example.json
DISCORD_DEFAULT_PROPOSAL=docs/examples/hermes_strategy_sandbox_example.json
DISCORD_TEAM_ALPHA_CHANNEL_ID=
DISCORD_TEAM_BETA_CHANNEL_ID=
DISCORD_TOURNAMENT_RESULTS_CHANNEL_ID=
DISCORD_STRATEGY_LAB_CHANNEL_ID=
DISCORD_PAPER_TRADING_LOG_CHANNEL_ID=
DISCORD_SCHEDULED_TEAM_UPDATES_ENABLED=false
DISCORD_SCHEDULED_TEAM_UPDATE_MINUTES=360
DISCORD_AUTONOMY_CONFIG_PATH=data/notes/team_autonomy_config.json

# Phase 7S: per-iteration Discord team-thought updates from the cheap loop.
# Disabled by default. When enabled, each loop iteration posts a concise "team
# room briefing" (gate decision + PM stance + thesis + learning + SPY-relative
# performance + broker outcomes) to each team's channel. Paper-only; never sends
# secrets; Discord failures never crash the loop.
ENABLE_DISCORD_ITERATION_UPDATES=false
DISCORD_POST_WHEN_MARKET_CLOSED=false
DISCORD_POST_REVIEW_ONLY=true
DISCORD_POST_FULL_CYCLE=true
DISCORD_POST_CHEAP_SKIP=false
DISCORD_POST_BROKER_EVENTS=true
DISCORD_POST_SCOREBOARD_SUMMARY=true
DISCORD_POST_COMPETITION_SUMMARY=true
# tournament_results or paper_trading_log
DISCORD_COMPETITION_SUMMARY_CHANNEL=tournament_results
DISCORD_ITERATION_UPDATE_STYLE=brief
DISCORD_ITERATION_UPDATE_MAX_CHARS=1800
DISCORD_UPDATE_MIN_INTERVAL_SECONDS=300

# Phase 7T: optional Discord post of the compact "Tomorrow Plan" after the
# export command (or market close). Disabled by default; never posts every loop.
# Channel is a special channel name (strategy_lab) or "team_channels" to post to
# each team's own channel. Paper-only; secrets are redacted; failures never crash.
DISCORD_POST_TOMORROW_PLAN=false
DISCORD_TOMORROW_PLAN_CHANNEL=strategy_lab

# Phase 7T: strict off-hours quiet mode for run-cheap-competition-loop. When the
# market is closed the process stays ALIVE but goes quiet — no LLM calls, no
# Alpaca live-equity refresh, no attribution refresh, no daily-review export, no
# Discord posts, no full/review cycles. It prints one sleep notice per closed
# stretch, then sleeps. Each ALLOW_OFF_HOURS_* flag re-enables exactly one action
# while closed; defaults keep everything quiet. Deterministic risk gates and the
# kill switch remain authoritative regardless of these flags.
STRICT_MARKET_HOURS_ONLY=true
ALLOW_OFF_HOURS_STATUS_REFRESH=false
ALLOW_OFF_HOURS_ATTRIBUTION_REFRESH=false
ALLOW_OFF_HOURS_LIVE_EQUITY_REFRESH=false
ALLOW_OFF_HOURS_DISCORD=false
ALLOW_OFF_HOURS_LLM_REVIEW=false
OFF_HOURS_POST_ONE_SLEEP_NOTICE=true

# Explicit opt-in only. Leave false unless you want gated autonomous paper cycles.
TEAM_ALPHA_AUTONOMY_ENABLED=false
TEAM_BETA_AUTONOMY_ENABLED=false
TEAM_ALPHA_AUTONOMY_MODE=paper_stocks_only
TEAM_BETA_AUTONOMY_MODE=paper_stocks_only
TEAM_ALPHA_MAX_PAPER_ORDERS_PER_DAY=3
TEAM_BETA_MAX_PAPER_ORDERS_PER_DAY=3
TEAM_ALPHA_MAX_DAILY_NOTIONAL=50000
TEAM_BETA_MAX_DAILY_NOTIONAL=50000
TEAM_ALPHA_REQUIRE_RISK_AGENT_APPROVAL=true
TEAM_BETA_REQUIRE_RISK_AGENT_APPROVAL=true
TEAM_ALPHA_REQUIRE_REVIEW_AGENT_APPROVAL=true
TEAM_BETA_REQUIRE_REVIEW_AGENT_APPROVAL=true

# Team-specific Alpaca paper accounts.
# Never commit real team keys.
TEAM_ALPHA_ALPACA_API_KEY=your_team_alpha_paper_key_here
TEAM_ALPHA_ALPACA_SECRET_KEY=your_team_alpha_paper_secret_here
TEAM_ALPHA_ALPACA_PAPER=true
TEAM_ALPHA_ALPACA_BASE_URL=https://paper-api.alpaca.markets

TEAM_BETA_ALPACA_API_KEY=your_team_beta_paper_key_here
TEAM_BETA_ALPACA_SECRET_KEY=your_team_beta_paper_secret_here
TEAM_BETA_ALPACA_PAPER=true
TEAM_BETA_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Phase 7V: paper portfolio management (position review + sell-to-close) ---
# Conservative paper-only limits for the position-management stage. Sell-to-close
# reduces/closes EXISTING long stock positions only - it can never open or
# increase a short. No shorting, options, margin, or live trading is added.
# Long entry uses ENABLE_PAPER_STOCKS (above); sell-to-close is tracked separately
# and is OFF by default, so enabling position reductions is an explicit choice.
ENABLE_PAPER_SELL_TO_CLOSE=false
# MAX_POSITION_PCT and MAX_DAILY_ORDERS_PER_TEAM are reused from above.
MAX_PORTFOLIO_GROSS_EXPOSURE_PCT=1.0
MAX_POSITION_TRIMS_PER_DAY=3
MAX_POSITION_EXITS_PER_DAY=2
MAX_CAPITAL_ROTATIONS_PER_DAY=1
MAX_DAILY_NOTIONAL_PER_TEAM=100000
# Emergency buying-power protection: below this fraction of equity, new buys are
# blocked and bounded capital-freeing trims/exits are permitted (never a full
# auto-liquidation).
EMERGENCY_BUYING_POWER_PCT=0.05
CONCENTRATION_ALERT_PCT=0.25

# --- Phase 7W: bounded memory, retention & prompt caps ---
# Retention windows (days) for raw runtime artifacts. Durable playbook lessons are
# never auto-deleted (stale ones are marked superseded). Cleanup is dry-run unless
# you pass --apply. None of this changes risk limits, code, or broker permissions.
MEMORY_DAILY_SUMMARY_RETENTION_DAYS=90
MEMORY_RAW_AUDIT_RETENTION_DAYS=30
MEMORY_AGENT_RESPONSE_RETENTION_DAYS=14
MEMORY_PROPOSAL_RETENTION_DAYS=30
MEMORY_KEEP_WEEKLY_ARCHIVES=true
MEMORY_MAX_PLAYBOOK_LESSONS_PER_TEAM=100
# Bound how much memory is injected into prompts (no raw history floods).
MEMORY_MAX_DAILY_SUMMARIES_IN_PROMPT=5
MEMORY_MAX_LESSONS_IN_PROMPT=10
# Optional override for the heartbeat path used by loop-health / loop-watchdog.
# LOOP_HEARTBEAT_PATH=data/runtime/loop_heartbeat.json
# Paper-trading log channel (preferred EOD destination; falls back to team channel).
# DISCORD_PAPER_TRADING_LOG_CHANNEL_ID=000000000000000000

# --- Phase 7X: live-loop automation (paper-only; no new execution authority) ---
# The continuously-running loop automatically sends the once-per-team/trading-date
# EOD report after the regular close (Alpaca clock/calendar gated) and runs the
# once-per-team/week synthesis after the last session of the week. Set to false to
# disable the automatic triggers (the manual export-eod-report / weekly-team-review
# commands still work). These never trade.
AUTO_EOD_REPORT=true
AUTO_WEEKLY_REVIEW=true
# Sell-to-close in the live loop stays gated by ENABLE_PAPER_SELL_TO_CLOSE (above,
# default false). When false the loop reviews positions and recommends trims/exits
# but submits none; long-entry buys still flow through all existing gates and are
# blocked whenever deterministic portfolio health requires a reduction.
