# Exalted Agent Trading Lab — configuration template
# Copy to .env and fill in your keys. Paper trading only; no live-trading mode exists.

# --- Team Alpaca paper accounts (create two paper accounts at alpaca.markets) ---
TEAM_ALPHA_ALPACA_API_KEY=
TEAM_ALPHA_ALPACA_SECRET_KEY=
TEAM_BETA_ALPACA_API_KEY=
TEAM_BETA_ALPACA_SECRET_KEY=

# --- LLM provider (openai | anthropic | ollama) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=            # if LLM_PROVIDER=anthropic
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1   # if LLM_PROVIDER=ollama
LLM_MODEL=gpt-5.4-nano
# Optional per-agent overrides (default to LLM_MODEL):
LLM_MODEL_STRATEGIST=gpt-5.4-mini
# LLM_MODEL_RESEARCHER=
# LLM_MODEL_RISK=

# --- Loop ---
CYCLE_MINUTES=30                # minutes between trading cycles while market is open
DRY_RUN=false                   # true = full pipeline but never submit orders

# --- Deterministic risk limits (hard caps; agents cannot bypass) ---
MAX_POSITION_PCT=0.15           # max single position, fraction of equity
MAX_GROSS_EXPOSURE=1.0          # sum(|positions|) / equity
MIN_CASH_PCT=0.05               # cash floor buys may not break
MAX_ORDERS_PER_DAY=40           # per team, New York trading date
MAX_DAILY_NOTIONAL=500000       # per team, dollars per day
ALLOW_SHORTS=true
MAX_PROPOSALS_PER_CYCLE=3

# --- Optional extras ---
# WATCHLIST=SPY,QQQ,AAPL,MSFT,NVDA,TSLA,AMD,META,GOOGL,AMZN
# DISCORD_BOT_TOKEN=            # post cycle/EOD summaries to Discord
# DISCORD_CHANNEL_ID=
