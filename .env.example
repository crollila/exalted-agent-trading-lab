# Alpaca paper trading only.
# Never commit real keys.
# Generic Alpaca keys are optional when using TEAM_ALPHA_* and TEAM_BETA_* paper keys.

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

DATABASE_PATH=data/trading_lab.sqlite3

DRY_RUN=true
STARTING_EQUITY=1000000
MIN_CASH_PCT=0.10
MAX_POSITION_PCT=0.20
MAX_DAILY_TURNOVER_PCT=0.30
MAX_NEW_POSITIONS_PER_DAY=10

# Optional local Discord command-center bot.
# Do not commit real tokens or IDs.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_DEFAULT_REGISTRY=docs/examples/hermes_team_registry_example.json
DISCORD_DEFAULT_PROPOSAL=docs/examples/hermes_strategy_sandbox_example.json
DISCORD_TEAM_ALPHA_CHANNEL_ID=
DISCORD_TEAM_BETA_CHANNEL_ID=
DISCORD_TOURNAMENT_RESULTS_CHANNEL_ID=
DISCORD_STRATEGY_LAB_CHANNEL_ID=
DISCORD_PAPER_TRADING_LOG_CHANNEL_ID=
DISCORD_SCHEDULED_TEAM_UPDATES_ENABLED=false
DISCORD_SCHEDULED_TEAM_UPDATE_MINUTES=360
DISCORD_AUTONOMY_CONFIG_PATH=data/notes/team_autonomy_config.json

# Explicit opt-in only. Leave false unless you want gated autonomous paper cycles.
TEAM_ALPHA_AUTONOMY_ENABLED=false
TEAM_BETA_AUTONOMY_ENABLED=false
TEAM_ALPHA_AUTONOMY_MODE=paper_stocks_only
TEAM_BETA_AUTONOMY_MODE=paper_stocks_only
TEAM_ALPHA_MAX_PAPER_ORDERS_PER_DAY=3
TEAM_BETA_MAX_PAPER_ORDERS_PER_DAY=3
TEAM_ALPHA_MAX_DAILY_NOTIONAL=50000
TEAM_BETA_MAX_DAILY_NOTIONAL=50000
TEAM_ALPHA_REQUIRE_RISK_AGENT_APPROVAL=true
TEAM_BETA_REQUIRE_RISK_AGENT_APPROVAL=true
TEAM_ALPHA_REQUIRE_REVIEW_AGENT_APPROVAL=true
TEAM_BETA_REQUIRE_REVIEW_AGENT_APPROVAL=true

# Team-specific Alpaca paper accounts.
# Never commit real team keys.
TEAM_ALPHA_ALPACA_API_KEY=your_team_alpha_paper_key_here
TEAM_ALPHA_ALPACA_SECRET_KEY=your_team_alpha_paper_secret_here
TEAM_ALPHA_ALPACA_PAPER=true
TEAM_ALPHA_ALPACA_BASE_URL=https://paper-api.alpaca.markets

TEAM_BETA_ALPACA_API_KEY=your_team_beta_paper_key_here
TEAM_BETA_ALPACA_SECRET_KEY=your_team_beta_paper_secret_here
TEAM_BETA_ALPACA_PAPER=true
TEAM_BETA_ALPACA_BASE_URL=https://paper-api.alpaca.markets
